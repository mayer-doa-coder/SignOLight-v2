# ===========================
# SignLearn Backend Config
# ===========================

# Google AI Studio API key for Gemma 4 (get a free-tier key from https://aistudio.google.com/apikey)
GEMMA_API_KEY=your-google-ai-studio-key-here

# REQUIRED — exact Gemma 4 model ID as listed in the Google AI Studio model picker.
# No default is hardcoded: guessing a model ID risks silently calling the wrong model.
GEMMA_MODEL=

# Number of captions translated per Gemma request
GEMMA_BATCH_SIZE=10

# Frontend URL for CORS (your Vercel/Netlify URL)
FRONTEND_URL=http://localhost:3000

# Port (Render sets this automatically)
PORT=5000
