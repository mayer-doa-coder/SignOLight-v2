{
  "name": "signlearn",
  "version": "1.0.0",
  "description": "AI-powered Sign Language Video Player for inclusive education",
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "sync:vocab": "node scripts/sync-sign-vocabulary.js",
    "vrm:verify": "node scripts/verify-vrm.js frontend/public/models/sign.vrm",
    "vrm:add-brows": "node scripts/add-brows.js frontend/public/models/sign.vrm"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
