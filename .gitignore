node_modules/
.env
.DS_Store
*.log
frontend/build/
frontend/.env
backend/.env

# Python (backend_nlp) artifacts
__pycache__/
*.py[cod]
.venv/
venv/

# Verification / diagnostic artifacts (regenerated by scripts, not shipped)
frontend/verify-*.png
frontend/video-frames/

# Local VRM safety backup created by scripts/add-brows.js (large, regenerable)
frontend/public/models/*.original.vrm
# Ship real video caches so Render can serve them before contacting YouTube.
# Render's free runtime filesystem is ephemeral, so an ignored local cache is
# not a deployment cache. Keep only diagnostics and mutable gap telemetry out.
backend/cache/*
!backend/cache/*.json
backend/cache/long-video-probe.json
backend/cache/probe-demo-video.json
backend/cache/vocabulary_gaps.json
